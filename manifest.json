{
    "manifest_version": 3,
    "name": "pageFixr",
    "version": "1.1",
  
    "description": "An extension that fixes some unimportant things in a page to improve readability.",
  
    "browser_specific_settings": {
        "gecko": {
            "id": "pagefixr@thecheesespot.xyz",
            "data_collection_permissions": {
              "required": [
                "none"
              ]
            },
            "strict_min_version": "58.0"
        }
    },
    
    "icons": {
      "48": "icons/bogoc-48.jpg"
    },
  
    "content_scripts": [
      {
        "js": ["pageFixr.js"],
        "matches": ["<all_urls>"]
      }
    ],

    "host_permissions": [
        "<all_urls>"
    ]
}